# ============================================
# Cross-Matter Navigator - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# OpenAI API Key (REQUIRED)
# Get yours at https://platform.openai.com/api-keys
# Models used: gpt-4o (complex agents), gpt-4o-mini (simpler agents)
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Override default models per agent
# CROSS_MATTER_MODEL=gpt-4o
# EXPERT_FINDER_MODEL=gpt-4o-mini
# REGULATORY_RADAR_MODEL=gpt-4o
# CULTURAL_BRIDGE_MODEL=gpt-4o-mini
# WORKLOAD_OPTIMIZER_MODEL=gpt-4o-mini
